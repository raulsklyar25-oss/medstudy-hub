[Unit]
Description=MedStudy Hub Node.js Backend Service
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/medstudy-hub/backend
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5
Environment=PORT=5000
Environment=NODE_ENV=production
# Load variables from .env file (if using dotenv)
# EnvironmentFile=/var/www/medstudy-hub/backend/.env

[Install]
WantedBy=multi-user.target
